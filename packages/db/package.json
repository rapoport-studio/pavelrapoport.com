{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:migrate": "supabase db push --db-url \"$DATABASE_URL\"",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > src/generated-types.ts"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
